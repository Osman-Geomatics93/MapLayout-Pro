{
  "manifest_version": 3,
  "name": "MapLayout Pro",
  "version": "1.3.0",
  "description": "Professional cartographic map layouts from your browser — no desktop GIS required.",
  "author": "Osman O. A. Ibrahim",
  "homepage_url": "https://osman-geomatics93.online/",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "src/ui/popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "MapLayout Pro"
  },
  "background": {
    "service_worker": "bg/service-worker.js",
    "type": "module"
  },
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "*://*.openstreetmap.org/*",
    "*://*.openstreetmap.fr/*",
    "*://*.openstreetmap.de/*",
    "*://*.openstreetmap.bzh/*",
    "*://*.opentopomap.org/*",
    "*://*.openseamap.org/*",
    "*://*.opensnowmap.org/*",
    "*://*.openrailwaymap.org/*",
    "*://*.openaip.net/*",
    "*://openfiremap.org/*",
    "*://*.arcgis.com/*",
    "*://*.arcgisonline.com/*",
    "*://*.google.com/*",
    "*://*.cartocdn.com/*",
    "*://*.nationalmap.gov/*",
    "*://*.earthdata.nasa.gov/*",
    "*://*.usgs.gov/*",
    "*://*.blm.gov/*",
    "*://*.fws.gov/*",
    "*://*.mrlc.gov/*",
    "*://*.githubusercontent.com/*",
    "*://github.com/*",
    "*://*.geoboundaries.org/*",
    "*://*.strava.com/*",
    "*://*.amazonaws.com/*",
    "*://*.autonavi.com/*",
    "*://tile.osm.ch/*",
    "*://tiles.wmflabs.org/*",
    "*://tile.waymarkedtrails.org/*",
    "*://tile.mtbmap.cz/*",
    "*://tileserver.memomaps.de/*",
    "*://sgx.geodatenzentrum.de/*",
    "*://wmts.geo.admin.ch/*",
    "*://service.pdok.nl/*",
    "*://maps-a.onemap.sg/*",
    "*://*.freemap.sk/*",
    "*://*.justicemap.org/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://unpkg.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: *; connect-src 'self' *"
  }
}
